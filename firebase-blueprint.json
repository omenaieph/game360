{
  "entities": {
    "UserProfile": {
      "title": "User Profile",
      "description": "Stores user profile information, gaming stats, and preferences.",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "Unique identifier for the user." },
        "displayName": { "type": "string", "description": "The pilot name chosen by the user." },
        "email": { "type": "string", "format": "email", "description": "User's email address." },
        "photoURL": { "type": "string", "format": "uri", "description": "URL to the user's avatar." },
        "role": { "type": "string", "enum": ["user", "admin"], "description": "User's role in the platform." },
        "createdAt": { "type": "string", "format": "date-time", "description": "When the profile was created." },
        "stats": {
          "type": "object",
          "properties": {
            "wins": { "type": "integer" },
            "losses": { "type": "integer" },
            "rank": { "type": "string" }
          }
        }
      },
      "required": ["uid", "displayName", "email", "role", "createdAt"]
    }
  },
  "firestore": {
    "/users/{uid}": {
      "schema": "UserProfile",
      "description": "Collection of user profiles."
    }
  }
}
